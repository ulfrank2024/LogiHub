generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  EXPEDITEUR
  TRANSPORTEUR
  RESPONSABLE_ENTREPOT
  ADMIN
}

enum ShipmentStatus {
  EN_ATTENTE         // Créé, en attente de dépôt
  DEPOSE             // Déposé au point de collecte
  EN_TRAITEMENT      // Traité par l'entreprise partenaire
  EN_TRANSIT         // En transit international
  ARRIVE_DESTINATION // Arrivé au point destination
  PRET_RETRAIT       // Prêt à être retiré
  EN_LIVRAISON       // En cours de livraison à domicile
  LIVRE              // Livré
  ANNULE
  LITIGE
}

enum DeliveryType {
  PICKUP          // Le destinataire vient chercher au point
  HOME_DELIVERY   // Livraison à l'adresse (frais supplémentaires)
}

enum PaymentMethod {
  STRIPE
  MOBILE_MONEY
  INTERAC
}

enum PaymentStatus {
  EN_ATTENTE
  PAYE
  REMBOURSE
  ECHOUE
}

enum RequestStatus {
  EN_ATTENTE
  APPROUVE
  REJETE
}

enum CompanyStatus {
  EN_ATTENTE
  ACTIVE
  SUSPENDUE
}

enum LocationType {
  DEPOT  // Dépôt client uniquement
  HUB    // Entrepôt / livraison uniquement
  MIXTE  // Dépôt ET collecte (les deux)
}

// ─── Utilisateurs ────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  firstName String
  lastName  String
  phone     String?
  role      Role
  country   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sentShipments    Shipment[]       @relation("Sender")
  carriedShipments Shipment[]       @relation("Carrier")
  managedCompany   LogisticsCompany? @relation("CompanyManager")
  companyRequest   CompanyRequest?
  notifications    Notification[]
}

// ─── Entreprises partenaires (entrepôts) ─────────────────────────────────────

model LogisticsCompany {
  id          String        @id @default(cuid())
  name        String
  email       String
  phone       String
  website     String?
  description String?
  status      CompanyStatus @default(EN_ATTENTE)
  managerId   String?       @unique
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  manager   User?               @relation("CompanyManager", fields: [managerId], references: [id])
  locations WarehouseLocation[]
  shipments Shipment[]
}

// ─── Points de l'entreprise (dépôt / hub) ────────────────────────────────────

model WarehouseLocation {
  id        String       @id @default(cuid())
  companyId String
  name      String       // "Point Douala", "Hub Montréal"
  country   String       // "CA" | "CM"
  city      String
  address   String
  type      LocationType @default(DEPOT)
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now())

  company           LogisticsCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  dropoffShipments  Shipment[]       @relation("DropoffLocation")
  deliveryShipments Shipment[]       @relation("DeliveryLocation")
  items             LocationItem[]
}

// ─── Suivi des colis par point ────────────────────────────────────────────────

model LocationItem {
  id         String    @id @default(cuid())
  locationId String
  shipmentId String
  arrivedAt  DateTime  @default(now())
  departedAt DateTime?

  location WarehouseLocation @relation(fields: [locationId], references: [id])
  shipment Shipment          @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
}

// ─── Demandes d'inscription entreprise ───────────────────────────────────────

model CompanyRequest {
  id          String        @id @default(cuid())
  userId      String        @unique
  companyName String
  email       String
  phone       String
  website     String?
  description String?
  locations   Json          // [{name, country, city, address, type}]
  status      RequestStatus @default(EN_ATTENTE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Envois ──────────────────────────────────────────────────────────────────

model Shipment {
  id                 String         @id @default(cuid())
  senderId           String
  carrierId          String?
  companyId          String?
  dropoffLocationId  String?
  deliveryLocationId String?
  deliveryType       DeliveryType   @default(PICKUP)
  status             ShipmentStatus @default(EN_ATTENTE)
  origin             String
  destination        String
  weight             Float
  dimensions         Json
  description        String
  declaredValue      Float
  price              Float
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  sender          User               @relation("Sender",          fields: [senderId],           references: [id])
  carrier         User?              @relation("Carrier",         fields: [carrierId],           references: [id])
  company         LogisticsCompany?  @relation(                   fields: [companyId],           references: [id])
  dropoffLocation  WarehouseLocation? @relation("DropoffLocation", fields: [dropoffLocationId],  references: [id])
  deliveryLocation WarehouseLocation? @relation("DeliveryLocation",fields: [deliveryLocationId], references: [id])
  tracking        TrackingEvent[]
  payment         Payment?
  items           LocationItem[]
}

// ─── Tracking ─────────────────────────────────────────────────────────────────

model TrackingEvent {
  id         String   @id @default(cuid())
  shipmentId String
  status     String
  location   String
  note       String?
  timestamp  DateTime @default(now())

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
}

// ─── Paiements ───────────────────────────────────────────────────────────────

model Payment {
  id         String        @id @default(cuid())
  shipmentId String        @unique
  amount     Float
  currency   String        @default("CAD")
  method     PaymentMethod
  status     PaymentStatus @default(EN_ATTENTE)
  stripeId   String?
  cinetpayId String?
  interacRef String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
